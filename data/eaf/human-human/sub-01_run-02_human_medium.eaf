            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a368" TIME_SLOT_REF1="ts117" TIME_SLOT_REF2="ts120">
                <ANNOTATION_VALUE>utan det måste ju fortfarande tränas på någonting som är relevant</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a369" TIME_SLOT_REF1="ts121" TIME_SLOT_REF2="ts122">
                <ANNOTATION_VALUE>så jag tänker att det såg ur säkert att få en AI som är ganska duktig på</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
