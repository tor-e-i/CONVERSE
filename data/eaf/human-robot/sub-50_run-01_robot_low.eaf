        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a304" TIME_SLOT_REF1="ts145" TIME_SLOT_REF2="ts148">
                <ANNOTATION_VALUE>Jag vet inte ens för vem är det då som kommer att tjäna kan man säkerställa att de själva inte har något form av bias i sig</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
