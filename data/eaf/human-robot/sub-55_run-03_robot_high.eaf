        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a398" TIME_SLOT_REF1="ts33" TIME_SLOT_REF2="ts36">
                <ANNOTATION_VALUE>Jag känner väl lite samma</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a399" TIME_SLOT_REF1="ts37" TIME_SLOT_REF2="ts39">
