        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a375" TIME_SLOT_REF1="ts97" TIME_SLOT_REF2="ts98">
                <ANNOTATION_VALUE>Det borde inte kanske ge så allvarliga konsekvenser som att man inte får dessutom något</ANNOTATION_VALUE>
