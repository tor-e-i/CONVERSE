        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a374" TIME_SLOT_REF1="ts95" TIME_SLOT_REF2="ts96">
                <ANNOTATION_VALUE>Att bara gå mot rött ljus</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
