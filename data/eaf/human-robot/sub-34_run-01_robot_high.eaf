            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a517" TIME_SLOT_REF1="ts447" TIME_SLOT_REF2="ts448">
                <ANNOTATION_VALUE>Nej det är konstigt</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a518" TIME_SLOT_REF1="ts454" TIME_SLOT_REF2="ts456">
                <ANNOTATION_VALUE>Men ja</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a519" TIME_SLOT_REF1="ts464" TIME_SLOT_REF2="ts465">
                <ANNOTATION_VALUE>Är det så</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a520" TIME_SLOT_REF1="ts472" TIME_SLOT_REF2="ts473">
                <ANNOTATION_VALUE>Det finns ju både för</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a521" TIME_SLOT_REF1="ts477" TIME_SLOT_REF2="ts481">
                <ANNOTATION_VALUE>Så kanske det var jag är faktiskt inte säker på hur det gick</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a522" TIME_SLOT_REF1="ts489" TIME_SLOT_REF2="ts496">
                <ANNOTATION_VALUE>Ja det är bra i sådana fall</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a523" TIME_SLOT_REF1="ts499" TIME_SLOT_REF2="ts506">
                <ANNOTATION_VALUE>Ja men jag kan tänka mig beroende på vilken indata som roboten får så skulle den kunna göra lite konstiga beslut</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a524" TIME_SLOT_REF1="ts507" TIME_SLOT_REF2="ts516">
                <ANNOTATION_VALUE>Men jag tror ändå att det kan vara värt att använda sig av robotdomare särskilt om man har en människa som bara dubbelkollar och övervakar att allting går som det ska att det är ett rimligt beslut Sen så kan jag tänka mig att det finns vissa fall som är så pass ovanliga att det nästan inte finns någon tidigare historik av det och då blir det väldigt svårt för roboten att veta hur den ska bete sig</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a525" TIME_SLOT_REF1="ts519" TIME_SLOT_REF2="ts522">
                <ANNOTATION_VALUE>I de fallen då kanske det</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
