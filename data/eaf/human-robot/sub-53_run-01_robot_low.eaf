        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a300" TIME_SLOT_REF1="ts45" TIME_SLOT_REF2="ts48">
                <ANNOTATION_VALUE>Ja absolut då var det dejting utifrån gentest</ANNOTATION_VALUE>
