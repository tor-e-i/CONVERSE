                <ANNOTATION_VALUE>Förutsatt att båda parter går med på att bli följda kanske till och med ömsesidigt så att barnen kan se var föräldrarna är föräldrar kan se var barnen är</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a693" TIME_SLOT_REF1="ts601" TIME_SLOT_REF2="ts602">
                <ANNOTATION_VALUE>Och att man kan stänga av appen när man vill</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a694" TIME_SLOT_REF1="ts603" TIME_SLOT_REF2="ts604">
                <ANNOTATION_VALUE>Om en förälder ska överraska sitt barn till exempel</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a695" TIME_SLOT_REF1="ts605" TIME_SLOT_REF2="ts606">
                <ANNOTATION_VALUE>Då kan ju inte barnet veta att den är och handlar på leksaksbutiken till exempel</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
    </TIER>
