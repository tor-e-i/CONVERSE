        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a362" TIME_SLOT_REF1="ts17" TIME_SLOT_REF2="ts18">
                <ANNOTATION_VALUE>Ett företag som har skapat en övervakningsfunktion som föräldrar kan installera på sina barns</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
