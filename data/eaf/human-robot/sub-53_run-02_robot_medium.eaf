        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a390" TIME_SLOT_REF1="ts25" TIME_SLOT_REF2="ts26">
                <ANNOTATION_VALUE>Föräldrar kan spåra sina barn och se vad de gör på aktiviteter</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a391" TIME_SLOT_REF1="ts27" TIME_SLOT_REF2="ts30">
                <ANNOTATION_VALUE>Och nu tänkte de släppa en ny app där barnen kan övervaka sina föräldrar istället</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a392" TIME_SLOT_REF1="ts31" TIME_SLOT_REF2="ts32">
